{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claude Code Plugin Manifest",
  "description": "Schema for .claude-plugin/plugin.json files",
  "type": "object",
  "required": ["name", "description", "version"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*[a-z0-9]$",
      "minLength": 2,
      "maxLength": 64
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 280
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)$"
    },
    "author": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      }
    }
  }
}
